# Copy to backend/.env for local API development.
# Must use the SAME SESSION_SECRET and DATABASE_URL as the repo-root .env.

PORT=4000
NODE_ENV=development

DATABASE_URL="postgresql://postgres:Letmein%4099x%21@localhost:5432/tailorsend"
SESSION_SECRET="change-me-to-a-long-random-string"

# Frontend origin(s) allowed by CORS + links in password-reset emails
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

SESSION_DAYS=30
RESET_TOKEN_HOURS=1

# Optional — password reset emails (leave blank to log links in dev)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="TailorSend <noreply@localhost>"
